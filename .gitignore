# ── Model weights (too large for Git, use Kaggle Output or HuggingFace Hub) ──
*.pth
*.pt
*.ckpt
*.h5
*.pkl

# ── Dataset files (not ours to redistribute) ──
*.jpg
*.jpeg
*.png
*.tif
*.tiff
*.csv
/data/
/datasets/
/input/

# ── Notebook checkpoints ──
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Python cache ──
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──
venv/
env/
.env/
.venv/

# ── OS files ──
.DS_Store
Thumbs.db
desktop.ini

# ── Kaggle working directory outputs ──
/kaggle/
/tmp/

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──
*.log
runs/
wandb/

# ── Keep the results folder images (these are OUR outputs, not dataset files) ──
!results/*.png
!results/*.jpg
